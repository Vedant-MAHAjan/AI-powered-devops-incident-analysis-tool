# AI DevOps Incident Copilot - Environment Configuration

# ===================
# Ollama Configuration
# ===================
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
# Fallback to mock LLM if Ollama is unavailable (true/false)
LLM_MOCK_MODE=true

# ===================
# GitHub Configuration
# ===================
# Create a GitHub Personal Access Token at: https://github.com/settings/tokens
# Required scopes: repo (for creating issues)
GITHUB_TOKEN=your_github_token_here
GITHUB_REPO_OWNER=your_github_username
GITHUB_REPO_NAME=ai-devops-copilot
# Set to true to skip actual GitHub API calls (for demo without token)
GITHUB_DRY_RUN=true

# ===================
# Application Settings
# ===================
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# Anomaly detection scan interval (seconds)
SCAN_INTERVAL=30

# Database path
DATABASE_URL=sqlite:///./data/incidents.db

# Log simulator settings
SIMULATOR_ENABLED=true
SIMULATOR_INTERVAL=2
# Number of log lines to generate per batch
SIMULATOR_BATCH_SIZE=10
